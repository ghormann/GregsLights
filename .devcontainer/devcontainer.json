{
  "name": "GregsLights",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    "source=gregs-lights-claude,target=/home/vscode/.claude,type=volume"
  ],
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/GregsLights",
  "remoteEnv": {
    "DISPLAY": "${localEnv:DISPLAY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.makefile-tools"
      ]
    }
  }
}
